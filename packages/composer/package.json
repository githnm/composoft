{
  "name": "@composoft/composer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "composoft": "./dist/cli.js"
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "compose:brand-x": "node dist/cli.js compose --brief fixtures/brand-x.md --registry @composoft/registry-acme --out ../examples/brand-x"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@composoft/registry-acme": "workspace:*",
    "@composoft/runtime": "workspace:*",
    "@composoft/spec": "workspace:*",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
