{
  "name": "@composoft/runtime",
  "version": "0.1.0-alpha.3",
  "description": "Server runtime for composoft compositions: resolves data slots, binds actions, hosts page-state, gates auth. React Server Components + a 'use client' renderer.",
  "license": "MIT",
  "author": "Hoshang Mehta",
  "repository": {
    "type": "git",
    "url": "https://github.com/githnm/composoft.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/githnm/composoft#readme",
  "bugs": {
    "url": "https://github.com/githnm/composoft/issues"
  },
  "keywords": [
    "composoft",
    "runtime",
    "react",
    "nextjs"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/_test.ts"
  },
  "dependencies": {
    "@composoft/spec": "workspace:*",
    "react": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
