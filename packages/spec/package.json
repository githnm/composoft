{
  "name": "@composoft/spec",
  "version": "0.1.0-alpha.0",
  "description": "Manifest contract for composoft: Adapter, Workflow, Block primitives plus Zod-backed validators. Zero runtime dependencies on React or Next.",
  "license": "MIT",
  "author": "Hoshang Mehta",
  "repository": {
    "type": "git",
    "url": "https://github.com/githnm/composoft.git",
    "directory": "packages/spec"
  },
  "homepage": "https://github.com/githnm/composoft#readme",
  "bugs": {
    "url": "https://github.com/githnm/composoft/issues"
  },
  "keywords": [
    "composoft",
    "spec",
    "manifests",
    "framework"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@types/react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
